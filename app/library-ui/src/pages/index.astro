<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Library</title>
  </head>

  <body>
    <h1>Library Books</h1>

    <ul id="books">
      <li>Loading books...</li>
    </ul>

    <script>
      async function loadBooks() {
        const booksElement: HTMLElement | null = document.getElementById("books");

        try {
          const response = await fetch("/odata/v4/library/Books");

          if (!response.ok) {
            throw new Error(`HTTP error ${response.status}`);
          }

          const data = await response.json();

          if (booksElement) {
            booksElement.innerHTML = "";
          }

          data.value.forEach((book: { title: string }) => {
            const li = document.createElement("li");
            li.textContent = book.title;
            if (booksElement) {
              booksElement.appendChild(li);
            }
          });
        } catch (error) {
          console.error("Error fetching books:", error);

          if (booksElement) {
            booksElement.innerHTML =
              "<li>Error loading books</li>";
          }
        }
      }

      loadBooks();
    </script>

    <style>
      h1 {
        color: orange;
      }

      li {
        margin: 8px 0;
      }
    </style>
  </body>
</html>