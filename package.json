{
  "name": "cap-class",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "type": "module",
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^3.0.2",
    "@sap/cds-dk": "^9.9.3",
    "@sap/eslint-plugin-cds": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "cap-js-mockdata": "^0.0.3",
    "eslint": "^10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.9.5",
    "tsx": "^4",
    "typescript": "^6.0.0"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "lint": "eslint . && pnpm -r --filter ./app/** run lint",
    "lint:fix": "eslint . --fix && pnpm -r --filter ./app/** run lint:fix",
    "format": "prettier . --write && pnpm -r --filter ./app/** run format",
    "format:check": "prettier . --check && pnpm -r --filter ./app/** run format:check",
    "check": "pnpm lint && pnpm format:check && pnpm -r --filter ./app/** run check",
    "prepare": "husky"
  },
  "lint-staged": {
    "srv/**/*.{js,mjs,cjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.cds": [
      "eslint --fix"
    ],
    "app/library-ui/**/*.{js,mjs,cjs,ts,astro}": [
      "pnpm --dir app/library-ui lint:fix",
      "pnpm --dir app/library-ui format"
    ],
    "**/*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite"
      },
      "auth": {
        "kind": "dummy"
      }
    }
  },
  "private": true,
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
